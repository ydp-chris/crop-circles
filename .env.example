# Copy to .env and fill in. Never commit .env.
#
# Get the connection string from Supabase:
#   Dashboard → Project Settings → Database → Connection string
#   Pick the "Transaction" pooler (port 6543) — best for many short queries.
#
# Format:
#   postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres
#
# For ValleySomm the project-ref is sodzbrrgcvtznosboznq.

DATABASE_URL=postgresql://postgres.sodzbrrgcvtznosboznq:REPLACE_ME@REGION.pooler.supabase.com:6543/postgres

# Phase 2 LLM extraction (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
